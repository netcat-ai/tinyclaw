{
  "name": "tinyclaw-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal room-scoped agent runtime for TinyClaw",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "test:live": "npm run build && TINYCLAW_RUN_LIVE=1 node --test test/live-smoke.test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/claude-code": "^2.1.72",
    "zod": "^4.3.6"
  }
}
